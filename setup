#!/bin/bash

cd scripts

# Install Nix
source install_nix.sh

# Function to install packages via Nix
install_nix_packages() {
  local packages=("$@")
  for package in "${packages[@]}"; do
    echo "Installing $package..."
    if nix-env -iA "$package"; then
      echo "$package installed successfully."
    else
      echo "Error: Failed to install $package."
    fi
  done
}

# Check if Nix is available
if ! command -v nix >/dev/null 2>&1; then
  echo "Error: Nix is not installed. Please check the installation."
  exit 1
fi

# Define package arrays
ESSENTIAL_DEPS=(
  "nixpkgs.bat"
  "nixpkgs.curl"
  "nixpkgs.file"
  "nixpkgs.fontconfig"
  "nixpkgs.git"
  "nixpkgs.procps"
  "nixpkgs.stow"
  "nixpkgs.unzip"
  "nixpkgs.p7zip"
  "nixpkgs.wget"
  "nixpkgs.xclip"
)

NERD_FONTS=(
  "nixpkgs.nerdfonts.fira-code"
  "nixpkgs.nerdfonts.hack"
)

LAZYVIM_BUNDLE=(
  "nixpkgs.rustc"
  "nixpkgs.cargo"
  "nixpkgs.neovim"
  "nixpkgs.fd"
  "nixpkgs.fzf"
  "nixpkgs.ripgrep"
  "nixpkgs.lazygit"
  "nixpkgs.nodejs"
  "nixpkgs.pyright"
)

BASH_UTILITIES=(
  "nixpkgs.tmux"
  "nixpkgs.nnn"
  "nixpkgs.zoxide"
)

# Install packages
echo "Installing essential dependencies..."
install_nix_packages "${ESSENTIAL_DEPS[@]}"

echo "Installing Nerd Fonts..."
install_nix_packages "${NERD_FONTS[@]}"

echo "Installing LazyVim bundle..."
install_nix_packages "${LAZYVIM_BUNDLE[@]}"

echo "Installing Bash utilities..."
install_nix_packages "${BASH_UTILITIES[@]}"

# Personal configurations
source setup_gitconfig.sh
source backup_and_stow.sh
